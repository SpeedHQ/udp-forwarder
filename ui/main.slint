import { Button, LineEdit, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

struct ForwardTarget {
    ip: string,
    port: string,
    note: string,
}

export global AppState {
    in-out property <string> listen-port: "5300";
    in-out property <[ForwardTarget]> targets: [
        { ip: "127.0.0.1", port: "5301" },
    ];
    in-out property <bool> running: false;
    in-out property <string> status-text: "Stopped";
    in-out property <int> packets-forwarded: 0;
    in-out property <string> version: "";

    callback start();
    callback stop();
    callback add-target();
    callback remove-target(int);
    callback save-config();
    callback update-target-ip(int, string);
    callback update-target-port(int, string);
    callback update-target-note(int, string);
}

component TargetRow inherits HorizontalLayout {
    in property <int> index;
    in-out property <string> ip;
    in-out property <string> port;
    in-out property <string> note;
    height: 36px;
    spacing: 8px;
    padding-right: 12px;

    LineEdit {
        placeholder-text: "IP address";
        text: ip;
        horizontal-stretch: 2;
        edited(value) => {
            AppState.update-target-ip(index, value);
        }
    }

    Text {
        text: ":";
        color: #a1a1aa;
        vertical-alignment: center;
        horizontal-stretch: 0;
    }

    LineEdit {
        placeholder-text: "Port";
        text: port;
        input-type: number;
        horizontal-stretch: 1;
        edited(value) => {
            AppState.update-target-port(index, value);
        }
    }

    LineEdit {
        placeholder-text: "Note";
        text: note;
        horizontal-stretch: 2;
        edited(value) => {
            AppState.update-target-note(index, value);
        }
    }

    Button {
        text: "Remove";
        clicked => {
            AppState.remove-target(index);
        }
    }
}

export component MainWindow inherits Window {
    title: "UDP Forwarder by Race HQ";
    preferred-width: 480px;
    preferred-height: 380px;
    background: #09090b;

    VerticalBox {
        padding: 20px;
        spacing: 16px;

        HorizontalLayout {
            Text {
                text: "UDP Forwarder by Race HQ";
                font-size: 18px;
                font-weight: 700;
                color: #fafafa;
                horizontal-stretch: 1;
            }
            Text {
                text: AppState.version;
                font-size: 12px;
                color: #a1a1aa;
                vertical-alignment: center;
            }
        }

        // Listen port
        Text { text: "Listen Port"; color: #a1a1aa; font-size: 12px; }
        HorizontalLayout {
            height: 36px;
            spacing: 8px;

            LineEdit {
                text <=> AppState.listen-port;
                input-type: number;
                placeholder-text: "5300";
                horizontal-stretch: 1;
            }
        }

        // Targets
        Text { text: "Forward To"; color: #a1a1aa; font-size: 12px; }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 8px;

                for target[index] in AppState.targets : TargetRow {
                    index: index;
                    ip: target.ip;
                    port: target.port;
                    note: target.note;
                }
            }
        }

        HorizontalLayout {
            height: 36px;
            spacing: 8px;

            Rectangle { horizontal-stretch: 1; }

            Button {
                text: "+ Add Target";
                clicked => { AppState.add-target(); }
            }
        }

        // Status + Save
        HorizontalLayout {
            height: 36px;
            spacing: 8px;

            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: AppState.running ? #22c55e : #3f3f46;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: AppState.status-text;
                color: #a1a1aa;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Button {
                text: "Save & Apply";
                clicked => { AppState.save-config(); }
            }
        }
    }
}
