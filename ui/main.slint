import { LineEdit, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

component BlueButton inherits Rectangle {
    in property <string> text;
    callback clicked;
    height: 28px;
    min-width: 80px;
    border-radius: 6px;
    background: ta.has-hover ? #2563eb : #3b82f6;
    animate background { duration: 120ms; }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            padding-left: 12px;
            padding-right: 12px;
            Text {
                text: root.text;
                color: #ffffff;
                font-size: 12px;
            }
        }
    }
}

component RedButton inherits Rectangle {
    in property <string> text;
    callback clicked;
    height: 28px;
    min-width: 70px;
    border-radius: 6px;
    background: ta.has-hover ? #dc2626 : #ef4444;
    animate background { duration: 120ms; }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            padding-left: 12px;
            padding-right: 12px;
            Text {
                text: root.text;
                color: #ffffff;
                font-size: 12px;
            }
        }
    }
}

component AppCheckBox inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked;
    callback toggled;
    height: 20px;
    width: box.width + 6px + label.width;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            checked = !checked;
            root.toggled();
        }
    }

    box := Rectangle {
        x: 0;
        y: (parent.height - self.height) / 2;
        width: 16px;
        height: 16px;
        border-radius: 3px;
        border-width: 1px;
        border-color: checked ? #3b82f6 : #52525b;
        background: checked ? #3b82f6 : transparent;

        if checked : Text {
            text: "✓";
            color: #ffffff;
            font-size: 11px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
    }

    label := Text {
        x: box.width + 6px;
        y: (parent.height - self.height) / 2;
        text: root.text;
        color: #a1a1aa;
        font-size: 12px;
    }
}

struct ForwardTarget {
    address: string,
    note: string,
    validation-error: string,
    is-duplicate: bool,
}

export global AppState {
    in-out property <string> listen-port: "9301";
    in-out property <[ForwardTarget]> targets: [
        { address: "127.0.0.1:5301" },
    ];
    in-out property <bool> running: false;
    in-out property <string> status-text: "Stopped";
    in-out property <int> packets-forwarded: 0;
    in-out property <int> packets-per-second: 0;
    in-out property <string> version: "";
    in-out property <bool> launch-on-startup: false;
    in-out property <bool> minimize-to-tray: false;
    in-out property <bool> has-pending-changes: false;
    in-out property <bool> has-errors: false;
    in-out property <string> error-text: "";
    in-out property <bool> update-available: false;
    in-out property <bool> update-checked: false;
    in-out property <string> latest-version: "";

    callback start();
    callback stop();
    callback add-target();
    callback remove-target(int);
    callback save-config();
    callback cancel-changes();
    callback toggle-launch-on-startup(bool);
    callback toggle-minimize-to-tray(bool);
    callback update-listen-port(string);
    callback update-target-address(int, string);
    callback update-target-note(int, string);
    callback open-github();
    callback open-release();
}

component TargetRow inherits VerticalLayout {
    in property <int> index;
    in-out property <string> address;
    in-out property <string> note;
    in property <string> validation-error;
    in property <bool> is-duplicate;
    spacing: 2px;
    padding-right: 12px;

    HorizontalLayout {
        height: 36px;
        spacing: 8px;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: is-duplicate ? #ef4444 : transparent;
            }
        }

        LineEdit {
            placeholder-text: "IP:Port (e.g. 127.0.0.1:5301)";
            text: address;
            horizontal-stretch: 2;
            edited(value) => {
                AppState.update-target-address(index, value);
            }
        }

        LineEdit {
            placeholder-text: "Note";
            text: note;
            horizontal-stretch: 2;
            edited(value) => {
                AppState.update-target-note(index, value);
            }
        }

        VerticalLayout {
            alignment: center;
            RedButton {
                text: "Remove";
                clicked => {
                    AppState.remove-target(index);
                }
            }
        }
    }

    if validation-error != "" : HorizontalLayout {
        height: 16px;
        Text {
            text: validation-error;
            color: #ef4444;
            font-size: 11px;
        }
    }
}

export component MainWindow inherits Window {
    title: "UDP Forwarder by SpeedHQ";
    icon: @image-url("icon.png");
    min-width: 480px;
    min-height: 300px;
    preferred-width: 680px;
    preferred-height: 380px;
    background: #09090b;

    VerticalBox {
        padding: 20px;
        spacing: 16px;

        HorizontalLayout {
            spacing: 8px;
            title-ta := TouchArea {
                mouse-cursor: pointer;
                width: title-text.preferred-width;
                clicked => { AppState.open-github(); }
                title-text := Text {
                    text: "UDP Forwarder by SpeedHQ";
                    font-size: 18px;
                    font-weight: 700;
                    color: title-ta.has-hover ? #60a5fa : #fafafa;
                    animate color { duration: 120ms; }
                }
            }
            if AppState.update-checked && !AppState.update-available : Text {
                text: AppState.version + " (up to date)";
                font-size: 12px;
                color: #fafafa;
                vertical-alignment: center;
            }
            if !AppState.update-checked || AppState.update-available : Text {
                text: AppState.version;
                font-size: 12px;
                color: #fafafa;
                vertical-alignment: center;
            }
            if AppState.update-available : Rectangle {
                height: 22px;
                border-radius: 4px;
                background: update-ta.has-hover ? #16a34a : #22c55e;
                animate background { duration: 120ms; }
                width: update-label.preferred-width + 16px;

                update-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { AppState.open-release(); }
                }
                update-label := Text {
                    text: AppState.latest-version + " available";
                    color: #ffffff;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            Rectangle { horizontal-stretch: 1; }
            AppCheckBox {
                text: "Minimize to tray";
                checked <=> AppState.minimize-to-tray;
                toggled => { AppState.toggle-minimize-to-tray(self.checked); }
            }
            AppCheckBox {
                text: "Launch on startup";
                checked <=> AppState.launch-on-startup;
                toggled => { AppState.toggle-launch-on-startup(self.checked); }
            }
        }

        // Listen port
        HorizontalLayout {
            height: 36px;
            spacing: 8px;

            Text { text: "Listen Port"; color: #a1a1aa; font-size: 12px; vertical-alignment: center; }
            LineEdit {
                text: AppState.listen-port;
                input-type: number;
                placeholder-text: "9301";
                width: 60px;
                edited(value) => {
                    AppState.update-listen-port(value);
                }
            }
            Rectangle { horizontal-stretch: 1; }
        }

        // Targets
        HorizontalLayout {
            height: 30px;
            spacing: 8px;

            Text { text: "Destinations (" + AppState.targets.length + ")"; color: #a1a1aa; font-size: 12px; vertical-alignment: center; }
            BlueButton {
                text: "Add New Destination";
                clicked => { AppState.add-target(); }
            }
            Rectangle { horizontal-stretch: 1; }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 8px;

                for target[index] in AppState.targets : TargetRow {
                    index: index;
                    address: target.address;
                    note: target.note;
                    validation-error: target.validation-error;
                    is-duplicate: target.is-duplicate;
                }
            }
        }

        // Status + Save
        HorizontalLayout {
            height: 36px;
            spacing: 8px;

            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: AppState.running ? #22c55e : #3f3f46;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: AppState.status-text;
                color: #a1a1aa;
                vertical-alignment: center;
            }

            if AppState.running && !AppState.has-errors : Text {
                text: AppState.packets-per-second + " pkt/s";
                color: #a1a1aa;
                font-size: 12px;
                vertical-alignment: center;
            }

            if AppState.has-errors : Text {
                text: AppState.error-text;
                color: #ef4444;
                font-size: 12px;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            if AppState.has-pending-changes : Rectangle {
                height: 30px;
                min-width: 70px;
                border-radius: 6px;
                background: cancel-ta.has-hover ? #dc2626 : #ef4444;
                animate background { duration: 120ms; }

                cancel-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { AppState.cancel-changes(); }
                }
                Text {
                    text: "Cancel";
                    color: #ffffff;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                property <bool> can-save: AppState.has-pending-changes && !AppState.has-errors;
                height: 30px;
                min-width: 80px;
                border-radius: 6px;
                background: can-save ? (save-ta.has-hover ? #2563eb : #3b82f6) : #3f3f46;
                animate background { duration: 120ms; }

                save-ta := TouchArea {
                    enabled: parent.can-save;
                    mouse-cursor: parent.can-save ? pointer : default;
                    clicked => { AppState.save-config(); }
                }
                Text {
                    text: "Save & Apply";
                    color: parent.can-save ? #ffffff : #71717a;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
