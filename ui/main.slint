import { LineEdit, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

component BlueButton inherits Rectangle {
    in property <string> text;
    callback clicked;
    height: 28px;
    min-width: 80px;
    border-radius: 6px;
    background: ta.has-hover ? #2563eb : #3b82f6;
    animate background { duration: 120ms; }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            padding-left: 12px;
            padding-right: 12px;
            Text {
                text: root.text;
                color: #ffffff;
                font-size: 12px;
            }
        }
    }
}

component RedButton inherits Rectangle {
    in property <string> text;
    callback clicked;
    height: 28px;
    min-width: 70px;
    border-radius: 6px;
    background: ta.has-hover ? #dc2626 : #ef4444;
    animate background { duration: 120ms; }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            padding-left: 12px;
            padding-right: 12px;
            Text {
                text: root.text;
                color: #ffffff;
                font-size: 12px;
            }
        }
    }
}

component AppCheckBox inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked;
    callback toggled;
    height: 20px;
    width: box.width + 6px + label.width;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            checked = !checked;
            root.toggled();
        }
    }

    box := Rectangle {
        x: 0;
        y: (parent.height - self.height) / 2;
        width: 16px;
        height: 16px;
        border-radius: 3px;
        border-width: 1px;
        border-color: checked ? #3b82f6 : #52525b;
        background: checked ? #3b82f6 : transparent;

        if checked : Text {
            text: "✓";
            color: #ffffff;
            font-size: 11px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
    }

    label := Text {
        x: box.width + 6px;
        y: (parent.height - self.height) / 2;
        text: root.text;
        color: #a1a1aa;
        font-size: 12px;
    }
}

struct ForwardTarget {
    address: string,
    note: string,
    validation-error: string,
    is-duplicate: bool,
}

struct ListenPort {
    key: string,
    port: string,
    enabled: bool,
    label: string,
    is-preset: bool,
}

export global AppState {
    in-out property <[ListenPort]> listen-ports: [];
    in-out property <int> active-tab: 0;  // 0 = Listen, 1 = Destinations
    in-out property <[ForwardTarget]> targets: [
        { address: "127.0.0.1:5301", note: "RaceIQ" },
    ];
    in-out property <bool> running: false;
    in-out property <string> status-text: "Stopped";
    in-out property <int> packets-forwarded: 0;
    in-out property <int> packets-per-second: 0;
    in-out property <string> version: "";
    in-out property <bool> launch-on-startup: false;
    in-out property <bool> minimize-to-tray: false;
    in-out property <bool> has-pending-changes: false;
    in-out property <bool> has-errors: false;
    in-out property <string> error-text: "";
    in-out property <bool> update-available: false;
    in-out property <bool> update-checked: false;
    in-out property <string> latest-version: "";

    callback start();
    callback stop();
    callback add-target();
    callback remove-target(int);
    callback save-config();
    callback cancel-changes();
    callback toggle-launch-on-startup(bool);
    callback toggle-minimize-to-tray(bool);
    callback update-listen-port-number(int, string);
    callback add-custom-listen-port();
    callback remove-listen-port(int);
    callback switch-tab(int);
    callback update-target-address(int, string);
    callback update-target-note(int, string);
    callback open-github();
    callback open-release();
}

component TargetRow inherits VerticalLayout {
    in property <int> index;
    in-out property <string> address;
    in-out property <string> note;
    in property <string> validation-error;
    in property <bool> is-duplicate;
    spacing: 2px;
    padding-right: 12px;

    HorizontalLayout {
        height: 36px;
        spacing: 8px;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: is-duplicate ? #ef4444 : transparent;
            }
        }

        LineEdit {
            placeholder-text: "IP:Port (e.g. 127.0.0.1:5301)";
            text: address;
            horizontal-stretch: 2;
            edited(value) => {
                AppState.update-target-address(index, value);
            }
        }

        LineEdit {
            placeholder-text: "Note";
            text: note;
            horizontal-stretch: 2;
            edited(value) => {
                AppState.update-target-note(index, value);
            }
        }

        VerticalLayout {
            alignment: center;
            RedButton {
                text: "Remove";
                clicked => {
                    AppState.remove-target(index);
                }
            }
        }
    }

    if validation-error != "" : HorizontalLayout {
        height: 16px;
        Text {
            text: validation-error;
            color: #ef4444;
            font-size: 11px;
        }
    }
}

component ListenPortRow inherits HorizontalLayout {
    in property <int> index;
    in-out property <string> port;
    in-out property <string> label;
    in property <bool> enabled;
    in property <bool> is-preset;
    height: 36px;
    spacing: 8px;
    padding-right: 12px;

    Text {
        text: label;
        color: #fafafa;
        font-size: 12px;
        vertical-alignment: center;
        min-width: 120px;
    }

    LineEdit {
        text: port;
        input-type: number;
        width: 70px;
        enabled: !is-preset;
        edited(value) => {
            AppState.update-listen-port-number(index, value);
        }
    }

    Rectangle { horizontal-stretch: 1; }

    if !is-preset : VerticalLayout {
        alignment: center;
        RedButton {
            text: "Remove";
            clicked => { AppState.remove-listen-port(index); }
        }
    }
}

export component MainWindow inherits Window {
    title: "UDP Forwarder by SpeedHQ";
    icon: @image-url("icon.png");
    min-width: 480px;
    min-height: 300px;
    preferred-width: 680px;
    preferred-height: 380px;
    background: #09090b;

    VerticalBox {
        padding: 20px;
        spacing: 16px;

        HorizontalLayout {
            spacing: 8px;
            title-ta := TouchArea {
                mouse-cursor: pointer;
                width: title-text.preferred-width;
                clicked => { AppState.open-github(); }
                title-text := Text {
                    text: "UDP Forwarder by SpeedHQ";
                    font-size: 18px;
                    font-weight: 700;
                    color: title-ta.has-hover ? #60a5fa : #fafafa;
                    animate color { duration: 120ms; }
                }
            }
            if AppState.update-checked && !AppState.update-available : Text {
                text: AppState.version + " (up to date)";
                font-size: 12px;
                color: #fafafa;
                vertical-alignment: center;
            }
            if !AppState.update-checked || AppState.update-available : Text {
                text: AppState.version;
                font-size: 12px;
                color: #fafafa;
                vertical-alignment: center;
            }
            if AppState.update-available : Rectangle {
                height: 22px;
                border-radius: 4px;
                background: update-ta.has-hover ? #16a34a : #22c55e;
                animate background { duration: 120ms; }
                width: update-label.preferred-width + 16px;

                update-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { AppState.open-release(); }
                }
                update-label := Text {
                    text: AppState.latest-version + " available";
                    color: #ffffff;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            Rectangle { horizontal-stretch: 1; }
            AppCheckBox {
                text: "Minimize to tray";
                checked <=> AppState.minimize-to-tray;
                toggled => { AppState.toggle-minimize-to-tray(self.checked); }
            }
            AppCheckBox {
                text: "Launch on startup";
                checked <=> AppState.launch-on-startup;
                toggled => { AppState.toggle-launch-on-startup(self.checked); }
            }
        }

        // Tab bar
        HorizontalLayout {
            height: 32px;
            spacing: 4px;

            Rectangle {
                min-width: 100px;
                height: 32px;
                border-radius: 6px;
                background: AppState.active-tab == 0 ? #1e3a5f : transparent;

                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { AppState.switch-tab(0); }
                }
                Text {
                    text: "Listen (" + AppState.listen-ports.length + ")";
                    color: AppState.active-tab == 0 ? #60a5fa : #a1a1aa;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                min-width: 120px;
                height: 32px;
                border-radius: 6px;
                background: AppState.active-tab == 1 ? #1e3a5f : transparent;

                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { AppState.switch-tab(1); }
                }
                Text {
                    text: "Destinations (" + AppState.targets.length + ")";
                    color: AppState.active-tab == 1 ? #60a5fa : #a1a1aa;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle { horizontal-stretch: 1; }
        }

        // Tab content
        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 8px;

                // Listen tab
                if AppState.active-tab == 0 : VerticalLayout {
                    spacing: 8px;

                    for lp[index] in AppState.listen-ports : ListenPortRow {
                        index: index;
                        port: lp.port;
                        label: lp.label;
                        enabled: lp.enabled;
                        is-preset: lp.is-preset;
                    }

                    HorizontalLayout {
                        height: 36px;
                        BlueButton {
                            text: "Add Custom Port";
                            clicked => { AppState.add-custom-listen-port(); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }

                // Destinations tab
                if AppState.active-tab == 1 : VerticalLayout {
                    spacing: 8px;

                    HorizontalLayout {
                        height: 30px;
                        spacing: 8px;
                        BlueButton {
                            text: "Add New Destination";
                            clicked => { AppState.add-target(); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }

                    for target[index] in AppState.targets : TargetRow {
                        index: index;
                        address: target.address;
                        note: target.note;
                        validation-error: target.validation-error;
                        is-duplicate: target.is-duplicate;
                    }
                }
            }
        }

        // Status + Save
        HorizontalLayout {
            height: 36px;
            spacing: 8px;

            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: AppState.running ? #22c55e : #3f3f46;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: AppState.status-text;
                color: #a1a1aa;
                vertical-alignment: center;
            }

            if AppState.running && !AppState.has-errors : Text {
                text: AppState.packets-per-second + " pkt/s";
                color: #a1a1aa;
                font-size: 12px;
                vertical-alignment: center;
            }

            if AppState.has-errors : Text {
                text: AppState.error-text;
                color: #ef4444;
                font-size: 12px;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            if AppState.has-pending-changes : Rectangle {
                height: 30px;
                min-width: 70px;
                border-radius: 6px;
                background: cancel-ta.has-hover ? #dc2626 : #ef4444;
                animate background { duration: 120ms; }

                cancel-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { AppState.cancel-changes(); }
                }
                Text {
                    text: "Cancel";
                    color: #ffffff;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                property <bool> can-save: AppState.has-pending-changes && !AppState.has-errors;
                height: 30px;
                min-width: 80px;
                border-radius: 6px;
                background: can-save ? (save-ta.has-hover ? #2563eb : #3b82f6) : #3f3f46;
                animate background { duration: 120ms; }

                save-ta := TouchArea {
                    enabled: parent.can-save;
                    mouse-cursor: parent.can-save ? pointer : default;
                    clicked => { AppState.save-config(); }
                }
                Text {
                    text: "Save & Apply";
                    color: parent.can-save ? #ffffff : #71717a;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
