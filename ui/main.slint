import { Button, LineEdit, GroupBox, VerticalBox, HorizontalBox, ListView, ScrollView } from "std-widgets.slint";

struct ForwardTarget {
    ip: string,
    port: string,
}

export global AppState {
    in-out property <string> listen-port: "5300";
    in-out property <[ForwardTarget]> targets: [
        { ip: "127.0.0.1", port: "5301" },
    ];
    in-out property <bool> running: false;
    in-out property <string> status-text: "Stopped";
    in-out property <int> packets-forwarded: 0;

    callback start();
    callback stop();
    callback add-target();
    callback remove-target(int);
    callback save-config();
    callback update-target-ip(int, string);
    callback update-target-port(int, string);
}

component TargetRow inherits HorizontalLayout {
    in property <int> index;
    in-out property <string> ip;
    in-out property <string> port;
    in property <bool> editable: true;
    spacing: 8px;

    LineEdit {
        placeholder-text: "IP address";
        text: ip;
        enabled: editable;
        horizontal-stretch: 3;
        edited(value) => {
            AppState.update-target-ip(index, value);
        }
    }

    Text {
        text: ":";
        vertical-alignment: center;
        horizontal-stretch: 0;
    }

    LineEdit {
        placeholder-text: "Port";
        text: port;
        enabled: editable;
        input-type: number;
        horizontal-stretch: 1;
        edited(value) => {
            AppState.update-target-port(index, value);
        }
    }

    Button {
        text: "Remove";
        enabled: editable;
        clicked => {
            AppState.remove-target(index);
        }
    }
}

export component MainWindow inherits Window {
    title: "UDP Forwarder";
    width: 480px;
    height: 420px;
    background: #1a1a2e;

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        // Header
        Text {
            text: "UDP Forwarder";
            font-size: 20px;
            font-weight: 700;
            color: #e0e0e0;
            horizontal-alignment: center;
        }

        // Listen port
        GroupBox {
            title: "Listen Port";

            HorizontalLayout {
                spacing: 8px;
                padding: 4px;

                LineEdit {
                    text <=> AppState.listen-port;
                    input-type: number;
                    placeholder-text: "5300";
                    enabled: !AppState.running;
                    horizontal-stretch: 1;
                }
            }
        }

        // Forwarding targets
        GroupBox {
            title: "Forward To";
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 8px;
                padding: 4px;

                for target[index] in AppState.targets : TargetRow {
                    index: index;
                    ip: target.ip;
                    port: target.port;
                    editable: !AppState.running;
                }

                Button {
                    text: "+ Add Target";
                    enabled: !AppState.running;
                    clicked => {
                        AppState.add-target();
                    }
                }
            }
        }

        // Status
        HorizontalLayout {
            spacing: 8px;
            alignment: center;

            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: AppState.running ? #4caf50 : #666;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: AppState.status-text;
                color: #b0b0b0;
                vertical-alignment: center;
            }
        }

        // Controls
        HorizontalLayout {
            spacing: 8px;
            alignment: center;

            Button {
                text: AppState.running ? "Stop" : "Start";
                clicked => {
                    if (AppState.running) {
                        AppState.stop();
                    } else {
                        AppState.start();
                    }
                }
            }

            Button {
                text: "Save Config";
                enabled: !AppState.running;
                clicked => {
                    AppState.save-config();
                }
            }
        }
    }
}
